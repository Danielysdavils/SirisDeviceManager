<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

     <!-- Background Color -->
    <Color x:Key="primaryBackColor1">#0d101b</Color>
    <Color x:Key="primaryBackColor2">#202427</Color>
    
    <!-- Color Palette -->
    <SolidColorBrush x:Key="colorOrange" Color="#a06300"/>
    <SolidColorBrush x:Key="colorOrangeLight" Color="#e08f0e" />
    <SolidColorBrush x:Key="colorGreenLight" Color="#34c234" />
    <SolidColorBrush x:Key="colorWhite" Color="#f5f5f5"/>
    <SolidColorBrush x:Key="colorWhiteLight" Color="DarkGray" />
    <SolidColorBrush x:Key="colorBlueLight" Color="#2d5062" />
    <SolidColorBrush x:Key="colorBlack" Color="Black" />
    <SolidColorBrush x:Key="colorDarkBlue" Color="#0d101b" />
</ResourceDictionary>