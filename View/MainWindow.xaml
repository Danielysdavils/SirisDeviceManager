<Window x:Class="SirisDeviceManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodel="clr-namespace:SirisDeviceManager.ViewModel"
        xmlns:device="clr-namespace:SirisDeviceManager.View.UserControls.Device"
        xmlns:login="clr-namespace:SirisDeviceManager.View.UserControls.Login"
        xmlns:local="clr-namespace:SirisDeviceManager"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Background="{StaticResource colorDarkBlue}"
        Title="MainWindow" Width="1280" Height="760"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <ResourceDictionary>
            <viewmodel:SirisDeviceManagerViewModel x:Key="vm" />
        </ResourceDictionary>
    </Window.Resources>

    <Border CornerRadius="10" DataContext="{StaticResource vm}">
        <Border CornerRadius="10" Opacity="0.9">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,1" EndPoint="1,0">
                    <GradientStop Color="{StaticResource primaryBackColor1}" Offset="0"/>
                    <GradientStop Color="{StaticResource primaryBackColor2}" Offset="0.75"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <materialDesign:Transitioner Grid.Row="0" AutoApplyTransitionOrigins="True" SelectedIndex="{Binding SelectedIndex}">
                    <materialDesign:TransitionerSlide OpeningEffect="{materialDesign:TransitionEffect FadeIn}">
                        <login:Login DataContext="{StaticResource vm}"/>
                    </materialDesign:TransitionerSlide>

                    <materialDesign:TransitionerSlide OpeningEffect="{materialDesign:TransitionEffect FadeIn}">
                        <device:DashboardDevice DataContext="{StaticResource vm}" />
                    </materialDesign:TransitionerSlide>
                </materialDesign:Transitioner>
            </Grid>
        </Border>
    </Border>
</Window>
