<UserControl x:Class="SirisDeviceManager.View.UserControls.Device.Resume.DeviceResume"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:viewmodel="clr-namespace:SirisDeviceManager.ViewModel"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:local="clr-namespace:SirisDeviceManager.View.UserControls.Device.Resume"
             d:DataContext="{d:DesignInstance Type=viewmodel:SirisDeviceManagerViewModel}"
             mc:Ignorable="d" 
             >
    <Border>
        <Grid Margin="15,10,10,10" DataContext="{Binding DeviceViewModel.DeviceResumeViewModel}">
            <Grid.RowDefinitions>
                <RowDefinition Height="100"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="70"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Margin="0,5,5,5" CornerRadius="20" Grid.Column="0">
                    <StackPanel Opacity="0.9">
                        <StackPanel>
                            <StackPanel Height="40" HorizontalAlignment="Left" VerticalAlignment="Center" Orientation="Horizontal">
                                <fa:IconImage Margin="15,0,10,0" Icon="Hive" Width="20" Height="20" Foreground="{StaticResource colorDarkBlue}" />
                                <TextBlock
                                 VerticalAlignment="Center"
                                 FontSize="15"
                                 FontWeight="Bold"
                                 Foreground="{StaticResource colorDarkBlue}" 
                                 Text="Serial Number: "/>
                                <TextBlock
                                VerticalAlignment="Center"
                                FontSize="15"
                                FontWeight="Bold"
                                Foreground="{StaticResource colorDarkBlue}"  
                                Text="{Binding SerialNumber}"/>
                            </StackPanel>

                            <StackPanel Height="40" VerticalAlignment="Center" HorizontalAlignment="Left" Orientation="Horizontal">
                                <fa:IconImage Margin="35,0,10,0" Icon="CaretRight" Width="20" Height="10" Foreground="{StaticResource colorDarkBlue}" />
                                <TextBlock
                                VerticalAlignment="Center"
                                FontWeight="Bold"
                                Foreground="{StaticResource colorDarkBlue}" 
                                Text="Ip: "/>
                                <TextBlock
                                FontWeight="Bold"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource colorDarkBlue}" 
                                Text="{Binding Ip}"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
           
            <Border Margin="5,5,5,5" CornerRadius="20" Grid.Row="1" >
                <ListBox ItemsSource="{Binding Logs}">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel IsItemsHost="True" Orientation="Vertical" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <ListBoxItem>
                                <TextBlock
                                     VerticalAlignment="Center"
                                     FontSize="15"
                                     Foreground="{StaticResource colorBlack}"  
                                     Text="{Binding}"/>
                            </ListBoxItem>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <StackPanel Orientation="Horizontal" Grid.Row="2">
                <StackPanel>
                    <TextBlock Margin="0,0,10,0" Foreground="{StaticResource colorDarkBlue}" VerticalAlignment="Center" Text="Delete device logs " />
                    <Button
                        BorderBrush="{StaticResource colorDarkBlue}"
                        Background="{StaticResource colorDarkBlue}"
                        Visibility="{Binding RestoreVisibility}"
                        Style="{StaticResource MaterialDesignFloatingActionMiniSecondaryButton}">
                        <Button.Content>
                            <fa:IconImage Foreground="{StaticResource colorWhite}" Icon="Trash" Style="{StaticResource iconButtonIcon}" />
                        </Button.Content>

                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="Click">
                                <i:InvokeCommandAction Command="{Binding DeleteLogsCommand}" />

                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </Button>
                </StackPanel>

                <StackPanel>
                    <TextBlock Margin="0,0,10,0" Foreground="{StaticResource colorDarkBlue}" VerticalAlignment="Center" Text="Reboot " />
                    <Button
                        BorderBrush="{StaticResource colorDarkBlue}"
                        Background="{StaticResource colorDarkBlue}"
                        Visibility="{Binding RestoreVisibility}"
                        Style="{StaticResource MaterialDesignFloatingActionMiniSecondaryButton}">   
                        <Button.Content>
                            <fa:IconImage Foreground="{StaticResource colorWhite}" Icon="Trash" Style="{StaticResource iconButtonIcon}" />
                        </Button.Content>

                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="Click">
                                <i:InvokeCommandAction Command="{Binding DeleteLogsCommand}" />
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
