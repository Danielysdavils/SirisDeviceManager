<UserControl x:Class="SirisDeviceManager.View.UserControls.Device.DashboardDevice"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:resume="clr-namespace:SirisDeviceManager.View.UserControls.Device.Resume"
             xmlns:list="clr-namespace:SirisDeviceManager.View.UserControls.Device.Panel.DeviceList"
             xmlns:toolbar="clr-namespace:SirisDeviceManager.View.UserControls.Device.Panel.DeviceManager"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             xmlns:viewmodel="clr-namespace:SirisDeviceManager.ViewModel"
             xmlns:local="clr-namespace:SirisDeviceManager.View.UserControls.Device"
             mc:Ignorable="d">

    <Border>
        <Border CornerRadius="20">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,1" EndPoint="1,0">
                    <GradientStop Color="#0d101b" Offset="0"/>
                    <GradientStop Color="#202427" Offset="0.90"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="900"/>
                    <ColumnDefinition Width="80*" />
                </Grid.ColumnDefinitions>

                <Border CornerRadius="10, 0, 0, 10" Grid.Column="0" Grid.RowSpan="2">
                    <Border.Background>
                        <SolidColorBrush />
                    </Border.Background>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="100" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="80" />
                                <RowDefinition Height="30" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions >

                            <StackPanel Grid.Row="0">
                                <StackPanel Orientation="Horizontal" Height="35" Margin="15,25,0,40">
                                    <TextBlock Margin="5,0,0,0" FontSize="11" VerticalAlignment="Center" Foreground="{StaticResource colorWhite}" Text="SiRIS DEVICE MANAGER" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Row="1" VerticalAlignment="Center" Orientation="Horizontal">
                                <TextBlock Margin="20,0,0,0" Text="Total de devices:" Foreground="DarkGray"/>
                                <TextBlock Margin="5,0,0,0" Foreground="DarkGray" Text="{Binding DeviceViewModel.DevicePanelViewModel.QtdDevices}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2">
                                <list:DeviceList />
                            </StackPanel>
                        </Grid>

                        <StackPanel Width="350" HorizontalAlignment="Center" VerticalAlignment="Top" Grid.Row="1">
                            <toolbar:ToolBar />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Main Section -->
                <Border CornerRadius="0,0,10,0" Grid.Column="1" Grid.ColumnSpan="3" Grid.RowSpan="2">
                    <Border.Background>
                        <SolidColorBrush Color="{StaticResource primaryBackColor1}"/>
                    </Border.Background>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="20"/>
                            <RowDefinition Height="45"/>
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- User bar -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Column="0">
                                <fa:IconImage Margin="35,0,10,0" Icon="Home" Width="20" Height="20" Foreground="{StaticResource colorWhite}" />
                                <TextBlock FontSize="16" Text="Dashboard" Foreground="{StaticResource colorWhite}"/>
                            </StackPanel>

                            <!-- User option -->
                            <StackPanel Grid.Column="1" 
                                    Orientation="Horizontal" 
                                    FlowDirection="RightToLeft" 
                                    VerticalAlignment="Center" 
                                    Margin="0,0,25,0">

                                <TextBlock Foreground="{StaticResource colorWhite}" FontFamily="12" VerticalAlignment="Center" Text="{Binding  DeviceViewModel.DeviceResumeViewModel.LoggedUsername}" />

                                <Ellipse Margin="10,0,10,0" StrokeThickness="1" Stroke="{StaticResource colorWhite}" Height="17" Width="17">
                                    <Ellipse.Fill >
                                        <ImageBrush ImageSource="/Images/user.png"/>
                                    </Ellipse.Fill>
                                </Ellipse>

                                <Button Tag="{StaticResource colorWhiteLight}" Style="{StaticResource iconButton}">
                                    <fa:IconImage Icon="PowerOff" Style="{StaticResource iconButtonIcon}" />
                                </Button>
                            </StackPanel>
                        </Grid>

                        <resume:DeviceResume Grid.Row="2" Background="{StaticResource colorWhite}" />
                    </Grid>
                </Border>


                <!--Modal-->
                <materialDesign:DialogHost 
                DataContext="{Binding DeviceViewModel.DevicePanelViewModel.DeviceManagerViewModel}" 
                DialogTheme="Inherit"
                IsOpen="{Binding IsModalOpen, Mode=TwoWay}">
                    <materialDesign:DialogHost.DialogContent>
                        <ContentControl Content="{Binding CurrentModal}" />
                    </materialDesign:DialogHost.DialogContent>
                </materialDesign:DialogHost>
            </Grid>
        </Border>
    </Border>
</UserControl>
