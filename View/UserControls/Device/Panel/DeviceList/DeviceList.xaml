<UserControl x:Class="SirisDeviceManager.View.UserControls.Device.Panel.DeviceList.DeviceList"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SirisDeviceManager.View.UserControls.Device.Panel.DeviceList"
             xmlns:viewmodel="clr-namespace:SirisDeviceManager.ViewModel"
             d:DataContext="{d:DesignInstance Type=viewmodel:SirisDeviceManagerViewModel}"
             mc:Ignorable="d" 
             >
    <Grid>
        <ListBox 
            Height="800"
            Panel.ZIndex="0" 
            DataContext="{Binding DeviceViewModel.DevicePanelViewModel.DeviceListViewModel}"
            ItemsSource="{Binding Devices}"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled">

            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" IsItemsHost="True"/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <ListBoxItem>
                        <local:DeviceItem/>
                    </ListBoxItem>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
