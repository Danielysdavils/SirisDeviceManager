<UserControl x:Class="SirisDeviceManager.View.UserControls.Login.Login"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors" 
             xmlns:local="clr-namespace:SirisDeviceManager.View.UserControls.Login"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             Background="{StaticResource colorDarkBlue}"
             >
    <Border CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="150" />
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel 
                 Width="500"
                 Grid.Row="0"
                 VerticalAlignment="Center"
                 HorizontalAlignment="Center">
                    <TextBlock 
                     Text="Siris Device Manager" 
                     Foreground="{StaticResource colorWhite}"
                     FontSize="30" 
                     FontWeight="Medium" 
                     HorizontalAlignment="Center"
                     Margin="0,0,0,0"/>
                    <TextBlock 
                     Text="v0.0.1" 
                     HorizontalAlignment="Center"
                     VerticalAlignment="Bottom"
                     Foreground="{StaticResource colorWhite}"
                     FontSize="15" 
                     FontWeight="Medium"/>
                </StackPanel>

                <Grid Grid.Row="1" Margin="0,0,0,0" Width="400">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="400" />
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Width="400" HorizontalAlignment="Center" Height="480" VerticalAlignment="Top">
                        <TextBlock Text="Login: " Foreground="{StaticResource colorWhite}" FontSize="20" />

                        <TextBox
                         BorderBrush="{StaticResource colorWhite}"
                         Foreground="{StaticResource colorWhite}"
                         Height="50"
                         Margin="0,20,0, 100"
                         x:Name="Username"
                         Padding="20,0,0,0"
                         materialDesign:HintAssist.Hint="Username" 
                         Text="{Binding LoginViewModel.Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged }"
                         >

                            <TextBox.Background>
                                <ImageBrush ImageSource="/Images/user-icon.png" AlignmentX="Left" Stretch="None" />
                            </TextBox.Background>
                        </TextBox>

                        <PasswordBox
                              BorderBrush="{StaticResource colorWhite}"
                              x:Name="PasswordBox"
                              materialDesign:HintAssist.Hint="Password"
                              Foreground="{StaticResource colorWhite}"
                              materialDesign:TextFieldAssist.DecorationVisibility="Visible"
                              Style="{StaticResource MaterialDesignFloatingHintPasswordBox}"
                              Margin="0,0,0,100"
                              Height="50"
                              Padding="20,0,0,0"
                              PasswordChanged="PasswordBox_PasswordChanged">
                            <PasswordBox.Background>
                                <ImageBrush ImageSource="/Images/key-icon.png" AlignmentX="Left" Stretch="None"/>
                            </PasswordBox.Background>
                        </PasswordBox>

                        <Button x:Name="btnLogin"
                             BorderThickness="0"
                             Content="Log In"
                             Foreground="{StaticResource colorBlack}"
                             FontSize="12"
                             Cursor="Hand"
                             Width="150">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="{StaticResource colorWhite}"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource colorWhiteLight}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>

                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Width="150" Height="40"
                                         CornerRadius="20"
                                         Background="{TemplateBinding Background}">
                                        <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>

                            <i:Interaction.Triggers>
                                <i:EventTrigger EventName="Click">
                                    <i:InvokeCommandAction Command="{Binding LoginViewModel.LoginCommand}"/>
                                </i:EventTrigger>
                            </i:Interaction.Triggers>
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Row="1" VerticalAlignment="Center">
                        <TextBlock FontSize="15" HorizontalAlignment="Center" Foreground="{StaticResource colorWhite}" Text="{Binding LoginViewModel.State}" />
                    </StackPanel>
                    
                    <StackPanel Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal">
                        <Image Source="/Images/mtw_white.png"  Width="100" Margin="0,0,15,0"/>
                        <Image Source="/Images/logo1.png"  Width="100"/>
                    </StackPanel>
                </Grid>

            </Grid>
        </Grid>
    </Border>
</UserControl>
